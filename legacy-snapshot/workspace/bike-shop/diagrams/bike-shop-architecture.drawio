  <diagram name="Message Flow" id="page2">
    <mxGraphModel dx="1400" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="f_title" value="&lt;font style=&quot;font-size:22px;&quot;&gt;&lt;b&gt;Message Flow&lt;/b&gt; &amp;mdash; Request Lifecycle&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#1E293B;" parent="1" vertex="1">
          <mxGeometry x="400" y="20" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: User sends message -->
        <mxCell id="f1" value="&lt;b&gt;1&lt;/b&gt;&lt;br&gt;User sends message&lt;br&gt;in Slack channel" style="shape=mxgraph.general.person;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#C084FC;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="600" y="80" width="100" height="70" as="geometry" />
        </mxCell>

        <!-- Step 2: Slack routes to Bot -->
        <mxCell id="f2" value="&lt;b&gt;2&lt;/b&gt;&lt;br&gt;Slack routes&lt;br&gt;@mention to Bot" style="shape=mxgraph.general.cloud;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#7DD3FC;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="190" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Step 3: Handler receives event -->
        <mxCell id="f3" value="&lt;b&gt;3&lt;/b&gt;&lt;br&gt;Handler receives&lt;br&gt;Socket Mode event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#6EE7B7;strokeWidth=2;fontColor=#1E293B;fontSize=10;arcSize=12;" parent="1" vertex="1">
          <mxGeometry x="585" y="300" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Step 4: Mem0 recall -->
        <mxCell id="f4" value="&lt;b&gt;4&lt;/b&gt;&lt;br&gt;Mem0 recall()&lt;br&gt;user context" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#FCD34D;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="310" y="305" width="130" height="55" as="geometry" />
        </mxCell>

        <!-- Step 5: Semantic Router -->
        <mxCell id="f5" value="&lt;b&gt;5&lt;/b&gt;&lt;br&gt;Semantic Router&lt;br&gt;selects Spirit + Model" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#FCD34D;strokeWidth=2;fontColor=#1E293B;fontSize=10;size=0.25;" parent="1" vertex="1">
          <mxGeometry x="580" y="400" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Step 5b: DEEP_THINK decision -->
        <mxCell id="f5b" value="&lt;b&gt;[DEEP_THINK]?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#A78BFA;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="350" y="410" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="f5b_yes" value="&lt;font style=&quot;font-size:9px;color:#7C3AED;&quot;&gt;&lt;b&gt;YES&lt;/b&gt; &amp;rarr; Opus&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="260" y="422" width="80" height="26" as="geometry" />
        </mxCell>

        <!-- Step 6: Build prompt with spirit + memory -->
        <mxCell id="f6" value="&lt;b&gt;6&lt;/b&gt;&lt;br&gt;Build prompt:&lt;br&gt;spirit + memory + msg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#6EE7B7;strokeWidth=2;fontColor=#1E293B;fontSize=10;arcSize=12;" parent="1" vertex="1">
          <mxGeometry x="585" y="510" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Step 7: Spawn Claude Code CLI -->
        <mxCell id="f7" value="&lt;b&gt;7&lt;/b&gt;&lt;br&gt;subprocess: Claude Code CLI&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#64748B;&quot;&gt;stream-json output&lt;/font&gt;" style="shape=mxgraph.architecture.server;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#FCD34D;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="575" y="610" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Step 7b: CLI uses tools -->
        <mxCell id="f7b" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;CLI accesses:&lt;/b&gt;&lt;br&gt;GitHub (HTTPS)&lt;br&gt;MCP Servers (stdio)&lt;br&gt;Codebase (fs)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#FDA4AF;strokeWidth=1;fontColor=#1E293B;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="810" y="615" width="140" height="65" as="geometry" />
        </mxCell>

        <!-- Step 8: Langfuse trace -->
        <mxCell id="f8" value="&lt;b&gt;8&lt;/b&gt;&lt;br&gt;Langfuse trace&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#64748B;&quot;&gt;HTTP REST batch&lt;/font&gt;" style="shape=mxgraph.architecture.monitor;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#FDA4AF;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="310" y="610" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Step 9: Mem0 observe -->
        <mxCell id="f9" value="&lt;b&gt;9&lt;/b&gt;&lt;br&gt;Mem0 observe()&lt;br&gt;save new context" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#FCD34D;strokeWidth=2;fontColor=#1E293B;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="310" y="720" width="130" height="55" as="geometry" />
