        <mxCell id="sb_r8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#A78BFA;strokeWidth=1;dashed=1;" parent="1" source="sb_router" target="sp8" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sb_r9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#A78BFA;strokeWidth=1;dashed=1;" parent="1" source="sb_router" target="sp9" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== BOTTOM: Info Cards ===== -->
        <!-- Key Principles card -->
        <mxCell id="principles_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=1;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="60" y="670" width="700" height="200" as="geometry" />
        </mxCell>
        <mxCell id="principles_title" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Key Principles&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];strokeColor=none;fillColor=none;fontColor=#1E293B;" parent="1" vertex="1">
          <mxGeometry x="80" y="678" width="120" height="26" as="geometry" />
        </mxCell>
        <mxCell id="principles_text" value="&lt;font style=&quot;font-size:10px;color:#1E293B;&quot;&gt;&lt;b&gt;1. Spirits are platform-agnostic&lt;/b&gt; &amp;mdash; A spirit knows nothing about Slack, CLI, or any body.&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;It defines personality, expertise, and behavior patterns only.&lt;br&gt;&lt;br&gt;&lt;b&gt;2. Bodies are platform-specific&lt;/b&gt; &amp;mdash; A body handles I/O for one platform (Slack, CLI, API).&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;It manages events, threading, rate limits, and response formatting.&lt;br&gt;&lt;br&gt;&lt;b&gt;3. Any body can use any spirit&lt;/b&gt; &amp;mdash; The Semantic Router dynamically selects the best&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;spirit based on user intent, not on which body received the message.&lt;br&gt;&lt;br&gt;&lt;b&gt;4. Models are orthogonal&lt;/b&gt; &amp;mdash; Spirit selection and model selection are independent.&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;[DEEP_THINK] can escalate any spirit to Opus for complex reasoning.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="80" y="705" width="660" height="155" as="geometry" />
        </mxCell>

        <!-- Access Patterns card -->
        <mxCell id="access_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=1;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="800" y="670" width="700" height="200" as="geometry" />
        </mxCell>
        <mxCell id="access_title" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Access Patterns&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];strokeColor=none;fillColor=none;fontColor=#1E293B;" parent="1" vertex="1">
          <mxGeometry x="820" y="678" width="130" height="26" as="geometry" />
        </mxCell>
        <mxCell id="access_text" value="&lt;font style=&quot;font-size:10px;color:#1E293B;&quot;&gt;&lt;b&gt;Before CLI execution:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;handler &amp;rarr; Mem0.recall(user_id) &amp;rarr; inject context into prompt&lt;br&gt;&lt;br&gt;&lt;b&gt;During CLI execution:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;CLI &amp;rarr; GitHub (gh CLI / HTTPS)&lt;br&gt;&amp;nbsp;&amp;nbsp;CLI &amp;rarr; MCP Servers (stdio) &amp;mdash; memory-keeper, langfuse, drawio&lt;br&gt;&amp;nbsp;&amp;nbsp;CLI &amp;rarr; Codebase (filesystem read/write)&lt;br&gt;&lt;br&gt;&lt;b&gt;After CLI execution:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;handler &amp;rarr; Mem0.observe(response) &amp;rarr; save to vector memory&lt;br&gt;&amp;nbsp;&amp;nbsp;handler &amp;rarr; Langfuse.trace() &amp;rarr; HTTP REST batch to PostgreSQL&lt;br&gt;&amp;nbsp;&amp;nbsp;handler &amp;rarr; Slack.reply(thread_ts) &amp;rarr; post response in thread&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="820" y="705" width="660" height="155" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
