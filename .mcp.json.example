{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "mcp/github-server", "python", "server.py"],
      "env": {
        "GITHUB_APP_ORACLE_ID": "${GITHUB_APP_ORACLE_ID}",
        "GITHUB_APP_ORACLE_PEM_PATH": "${GITHUB_APP_ORACLE_PEM_PATH}",
        "GITHUB_APP_ORACLE_INSTALLATION_ID": "${GITHUB_APP_ORACLE_INSTALLATION_ID}",
        "GITHUB_APP_ORACLE_SLUG": "${GITHUB_APP_ORACLE_SLUG}",
        "GITHUB_APP_NEO_ID": "${GITHUB_APP_NEO_ID}",
        "GITHUB_APP_NEO_PEM_PATH": "${GITHUB_APP_NEO_PEM_PATH}",
        "GITHUB_APP_NEO_INSTALLATION_ID": "${GITHUB_APP_NEO_INSTALLATION_ID}",
        "GITHUB_APP_NEO_SLUG": "${GITHUB_APP_NEO_SLUG}",
        "GITHUB_APP_THE_ARCHITECT_ID": "${GITHUB_APP_THE_ARCHITECT_ID}",
        "GITHUB_APP_THE_ARCHITECT_PEM_PATH": "${GITHUB_APP_THE_ARCHITECT_PEM_PATH}",
        "GITHUB_APP_THE_ARCHITECT_INSTALLATION_ID": "${GITHUB_APP_THE_ARCHITECT_INSTALLATION_ID}",
        "GITHUB_APP_THE_ARCHITECT_SLUG": "${GITHUB_APP_THE_ARCHITECT_SLUG}",
        "GITHUB_APP_ID": "${GITHUB_APP_ID}",
        "GITHUB_APP_PEM_PATH": "${GITHUB_APP_PEM_PATH}",
        "GITHUB_APP_INSTALLATION_ID": "${GITHUB_APP_INSTALLATION_ID}",
        "GITHUB_APP_SLUG": "${GITHUB_APP_SLUG}"
      }
    },
    "mem0": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "mcp/mem0-server", "python", "server.py"],
      "env": {
        "QDRANT_HOST": "localhost",
        "QDRANT_PORT": "6333",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "MEM0_COLLECTION": "claude-code-memory",
        "MEM0_USER_ID": "claude-code"
      }
    },
    "langfuse": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp-servers/langfuse/index.js"],
      "env": {
        "LANGFUSE_HOST": "http://localhost:3000",
        "LANGFUSE_PUBLIC_KEY": "${LANGFUSE_PUBLIC_KEY}",
        "LANGFUSE_SECRET_KEY": "${LANGFUSE_SECRET_KEY}"
      }
    },
    "excalidraw": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "excalidraw-mcp"],
      "env": {}
    },
    "drawio": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "drawio-mcp"],
      "env": {}
    }
  }
}
