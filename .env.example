# =============================================================================
# Claude Code Foundation — Environment Variables
# =============================================================================
#
# Copy this file and set your values. These env vars are consumed by MCP
# servers configured in .mcp.json — NOT loaded from a .env file directly.
#
# After filling in your values, add them to .mcp.json under each server's
# "env" block. See README.md for details.
# =============================================================================

# ---------------------------------------------------------------------------
# GitHub MCP Server (mcp/github-server/)
# ---------------------------------------------------------------------------
# Create a GitHub App: https://docs.github.com/en/apps/creating-github-apps
# Install it on your org/user account, then fill in the values below.

GITHUB_APP_ID=                      # GitHub App ID (numeric)
GITHUB_APP_PEM_PATH=                # Path to the App's private key PEM file (e.g. ~/.ssh/my-app.pem)
GITHUB_APP_INSTALLATION_ID=         # Installation ID for the target org/user
GITHUB_APP_SLUG=                    # App slug shown as bot identity (e.g. my-bot-app)

# Optional: personal access token for operations that don't use App auth (e.g. issue creation without bot identity)
GITHUB_PERSONAL_ACCESS_TOKEN=       # GitHub PAT with repo scope

# ---------------------------------------------------------------------------
# Mem0 MCP Server (mcp/mem0-server/)
# ---------------------------------------------------------------------------
# Requires Qdrant (vector DB) and Ollama (embeddings) running locally.
# Start them: docker compose up -d qdrant ollama

QDRANT_HOST=localhost               # Qdrant server host
QDRANT_PORT=6333                    # Qdrant server port
OLLAMA_URL=http://localhost:11434   # Ollama API URL
OLLAMA_EMBED_MODEL=nomic-embed-text # Embedding model (pull: ollama pull nomic-embed-text)
OLLAMA_EMBED_DIMS=768               # Embedding dimensions (must match model)
MEM0_COLLECTION=claude-code-memory  # Qdrant collection name
MEM0_USER_ID=claude-code            # Default user scope for memories

# ---------------------------------------------------------------------------
# Langfuse (observability — optional)
# ---------------------------------------------------------------------------
# Self-hosted: docker compose up -d langfuse
# Cloud: https://langfuse.com

LANGFUSE_HOST=http://localhost:3000 # Langfuse server URL
LANGFUSE_PUBLIC_KEY=                # Langfuse public key
LANGFUSE_SECRET_KEY=                # Langfuse secret key
